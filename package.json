{
  "name": "cdcp-sandbox-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Encrypted WebSocket relay between the sandbox-reader Android app (reads real contactless cards via internal NFC) and the CDCP sandbox web app.",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
